{
  "name": "@ai-me-chat/react",
  "version": "0.4.0",
  "description": "AI-Me React UI components — chat panel, command palette, confirmation dialog",
  "license": "MIT",
  "keywords": [
    "ai",
    "copilot",
    "chatbot",
    "react",
    "chat-widget",
    "command-palette",
    "ai-assistant",
    "vercel-ai-sdk"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/aselims/ai-me-chat",
    "directory": "packages/react"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@ai-sdk/react": "^3.0.0",
    "ai": "^6.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@ai-me-chat/core": "workspace:*"
  },
  "devDependencies": {
    "@ai-sdk/react": "^3.0.118",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "ai": "^6.0.116",
    "happy-dom": "^20.8.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
